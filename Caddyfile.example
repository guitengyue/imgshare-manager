your-domain.com {
    @protected path / /stats /upload /delete* /renew* /topic* /bulk* /remove* /admin*
    basic_auth @protected {
        your-username your-bcrypt-password-hash
    }

    handle /thumb* {
        reverse_proxy imgshare-manager:8081
    }

    @files path /file/*
    handle @files {
        reverse_proxy microbin:8080 {
            header_down -Content-Disposition
        }
    }

    @public_uploads path_regexp public_uploads ^/upload/.+
    handle @public_uploads {
        reverse_proxy microbin:8080
    }

    @delete path /delete/*
    handle @delete {
        reverse_proxy imgshare-manager:8081
    }

    @renew path /renew/*
    handle @renew {
        reverse_proxy imgshare-manager:8081
    }

    @topic path /topic/*
    handle @topic {
        reverse_proxy imgshare-manager:8081
    }

    @bulk path /bulk
    handle @bulk {
        reverse_proxy imgshare-manager:8081
    }

    @stats path /stats
    handle @stats {
        reverse_proxy imgshare-manager:8081
    }

    @protected_upload path /upload
    handle @protected_upload {
        reverse_proxy imgshare-manager:8081
    }

    @root path /
    handle @root {
        reverse_proxy imgshare-manager:8081
    }

    handle {
        reverse_proxy microbin:8080
    }
}
